---
// src/layouts/MainLayout.astro
// Base layout for all pages

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Valkey - Open Source In-Memory Data Store' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
          Ubuntu, Cantarell, 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
          sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        background-color: #ffffff;
        color: #1a1a1a;
        line-height: 1.6;
      }

      header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      header h1 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
      }

      header p {
        font-size: 1rem;
        opacity: 0.9;
      }

      nav {
        background-color: #f8f9fa;
        padding: 1rem 2rem;
        border-bottom: 1px solid #eee;
        display: flex;
        gap: 2rem;
        justify-content: center;
      }

      nav a {
        color: #667eea;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      nav a:hover {
        color: #764ba2;
      }

      footer {
        background-color: #f8f9fa;
        padding: 2rem;
        border-top: 1px solid #eee;
        text-align: center;
        color: #666;
        margin-top: 3rem;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>🚀 Valkey Documentation</h1>
      <p>High-performance in-memory data store</p>
    </header>

    <nav>
      <a href="/">Home</a>
      <a href="/search">Search</a>
      <a href="/reference">Commands</a>
      <a href="/topics">Topics</a>
      <a href="/blog">Blog</a>
    </nav>

    <div style="max-width: 1200px; margin: 0 auto;">
      <slot />
    </div>

    <footer>
      <p>&copy; 2024 Valkey. Licensed under the Valkey Community License.</p>
    </footer>
  </body>
</html>
